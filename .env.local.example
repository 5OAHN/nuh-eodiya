# 카카오 개발자 콘솔 (https://developers.kakao.com)에서 발급
# JavaScript 키 (카카오 SDK 초기화 및 공유 API 사용)
VITE_KAKAO_JS_KEY=your_kakao_javascript_key_here

# 카카오맵 API 키 (JavaScript 앱 키와 동일한 경우가 많음)
VITE_KAKAO_MAP_KEY=your_kakao_map_api_key_here

# 앱 베이스 URL (Vercel 배포 후 실제 도메인으로 교체)
VITE_APP_BASE_URL=https://your-app.vercel.app
